{
  "name": "mdl",
  "version": "0.0.1",
  "description": "Interactive CLI for syncing music locally via YouTube.",
  "packageManager": "bun@1.3.10",
  "type": "module",
  "author": "Labithiotis",
  "license": "MIT",
  "keywords": [
    "cli",
    "mdl",
    "music",
    "downloader",
    "spotify",
    "apple music",
    "amazon music",
    "youtube music",
    "soundcloud",
    "bandcamp",
    "qobuz",
    "deezer",
    "tidal"
  ],
  "bin": {
    "mdl": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build --compile --minify ./src/cli.tsx --outfile release/mdl",
    "fmt": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "tsc --noEmit",
    "test": "bun run --filter . '/^test:/'",
    "test:unit": "bun test src",
    "test:e2e": "bun test e2e"
  },
  "dependencies": {
    "effect": "3.21.0",
    "ink": "6.8.0",
    "ink-scroll-view": "0.3.6",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "6.0.0",
    "react": "19.2.0",
    "sanitize-filename": "1.6.4",
    "youtubei.js": "17.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "latest",
    "@types/react": "19.2.2",
    "ink-testing-library": "4.0.0",
    "react-devtools-core": "7.0.1",
    "typescript": "6.0.2"
  }
}
