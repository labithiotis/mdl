{
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "lefthook install --reset-hooks-path",
    "fmt": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "bun run typecheck",
    "typecheck": "tsc --noEmit -p packages/cli/tsconfig.json",
    "test": "bun run test && bun run test:e2e",
    "test:unit": "bun run --filter '@mdlx/cli' test:unit",
    "test:e2e": "bun run --filter '@mdl/e2e' test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "latest",
    "lefthook": "2.1.5",
    "typescript": "6.0.2"
  },
  "packageManager": "bun@1.3.10",
  "knip": {
    "workspaces": {
      "packages/e2e": {
        "ignoreDependencies": [
          "react"
        ]
      }
    }
  }
}
